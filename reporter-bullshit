    vim.list_extend(command, {
      "--test-reporter", reporter_path,
    })
  end

  Option 2: Wrap the Built-in TAP Reporter

  If you want to reuse the built-in tap reporter:

  // wrapped-tap.js
  import { tap } from 'node:test/reporters';

  export default async function* wrappedTap(source) {
    // Clone the source stream because tap will consume it
    const events = [];

    // Collect events and inject location comments
    async function* augmentedSource() {
      for await (const event of source) {
        // Inject location before test events
        if (event.type === 'test:pass' || event.type === 'test:fail') {
          yield {
            type: 'test:diagnostic',
            data: {
              message: `location: ${event.data.file}:${event.data.line}:${event.data.column}`
            }
          };
        }
        yield event;
      }
    }

    // Forward to tap reporter
    for await (const line of tap(augmentedSource())) {
      yield line;
    }
  }

  Problem with Option 2: You can't easily clone/tee the source stream in JavaScript, so Option 1 is cleaner.
